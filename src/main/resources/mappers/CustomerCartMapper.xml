<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nextage.web.mapper.CustomerCartMapper">

    <!-- ── ResultMap ─────────────────────────────────────── -->
    <resultMap id="cartDTOMap" type="com.nextage.web.domain.CartDTO">
        <result property="cartItemId"  column="cart_item_id"/>
        <result property="kitId"       column="kit_id"/>
        <result property="productName" column="product_name"/>
        <result property="imageUrl"    column="image_url"/>
        <result property="price"       column="price"/>
        <result property="quantity"    column="quantity"/>
        <result property="kitStatus"   column="kit_status"/>  <!-- ✅ 추가 -->
    </resultMap>

    <!-- ── cart_id 조회 ──────────────────────────────────── -->
    <select id="selectCartIdByCustomerId" resultType="Long">
        SELECT cart_id
          FROM cart
         WHERE customer_id = #{customerId}
         LIMIT 1
    </select>

    <!-- ── cart 생성 ─────────────────────────────────────── -->
    <insert id="insertCart">
        INSERT INTO cart (customer_id, created_at)
        VALUES (#{customerId}, NOW())
    </insert>

    <!-- ── 생성된 cart_id 재조회 ─────────────────────────── -->
    <select id="selectLastInsertCartId" resultType="Long">
        SELECT cart_id
          FROM cart
         WHERE customer_id = #{customerId}
         ORDER BY cart_id DESC
         LIMIT 1
    </select>

    <!-- ── 장바구니 아이템 목록 조회 ─────────────────────── -->
    <!-- ✅ DELETED 상품 제외, SOLDOUT 상품은 포함하되 status 전달 -->
    <select id="selectCartItems" resultMap="cartDTOMap">
        SELECT
            ci.cart_item_id,
            ci.kit_id,
            k.name        AS product_name,
            k.main_image1 AS image_url,
            k.price,
            ci.quantity,
            k.status      AS kit_status
          FROM cart_items ci
          JOIN kit k ON ci.kit_id = k.kit_id
         WHERE ci.cart_id = #{cartId}
           AND k.status != 'DELETED'
         ORDER BY ci.cart_item_id DESC
    </select>

    <!-- ── 중복 체크 ──────────────────────────────────────── -->
    <select id="selectDuplicateCartItemId" resultType="Long">
        SELECT cart_item_id
          FROM cart_items
         WHERE cart_id = #{cartId}
           AND kit_id  = #{kitId}
         LIMIT 1
    </select>

    <!-- ── 아이템 추가 ────────────────────────────────────── -->
    <insert id="insertCartItem">
        INSERT INTO cart_items (cart_id, kit_id, quantity, created_at)
        VALUES (#{cartId}, #{kitId}, #{quantity}, NOW())
    </insert>

    <!-- ── 수량 누적 (중복 추가 시) ──────────────────────── -->
    <update id="updateCartItemQuantityAdd">
        UPDATE cart_items
           SET quantity = quantity + #{quantity}
         WHERE cart_item_id = #{cartItemId}
    </update>

    <!-- ── 수량 직접 변경 ────────────────────────────────── -->
    <update id="updateCartItemQuantity">
        UPDATE cart_items
           SET quantity = #{quantity}
         WHERE cart_item_id = #{cartItemId}
    </update>

    <!-- ── 단건 삭제 ─────────────────────────────────────── -->
    <delete id="deleteCartItem">
        DELETE FROM cart_items
         WHERE cart_item_id = #{cartItemId}
    </delete>

    <!-- ── 선택 삭제 (본인 cart_id 검증 포함) ───────────── -->
    <delete id="deleteCartItemsByIds">
        DELETE FROM cart_items
         WHERE cart_id = #{cartId}
           AND cart_item_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- ── 결제 완료 후 장바구니 아이템 삭제 ─────────────── -->
    <delete id="deleteCartItemsByIdsOnly">
        DELETE FROM cart_items
         WHERE cart_item_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>