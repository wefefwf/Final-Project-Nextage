<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nextage.web.mapper.CustomerShopMapper">


	<!-- 페이지에 해당하는 갯수맞게 가져오기 -->
	<select id="getKitListPaged" resultType="KitDTO">
	    SELECT * FROM kit 
	    <choose>
	        <when test="sort == 'price_desc'">
	            ORDER BY price DESC
	        </when>
	        <when test="sort == 'price_asc'">
	            ORDER BY price ASC
	        </when>
	        <otherwise>
	            ORDER BY kit_id DESC
	        </otherwise>
	    </choose>
	    LIMIT #{offset}, #{size}
	</select>
	
	<!-- 총갯수 -->
	<select id="getTotalKitCount" resultType="int">
	    SELECT COUNT(*) FROM kit
	</select>








</mapper>